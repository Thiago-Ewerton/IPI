#include <stdio.h>

int main(){

    char c;
    int max;
    int i, espaco;

    scanf(" %c", &c);

//Calculo da quantidade de linhas do triangulo
    max = (c - 'A' + 1);

    for(i = 1; i <= max; i++){
        // Pontos antes das letras
        for(espaco = 1; espaco <= max - i; espaco++){
            printf(".");
        }

        char letra = 'A';

        // parte crescente (letras)
        for(int j = 1; j <= i; j++){
            printf("%c", letra);
            letra++;
        }

        letra -= 2;

        // parte decrescente (letras)
        for(int j = 1; j < i; j++){
            printf("%c", letra);
            letra--;
        }

        // Pontos após as letras
        for(espaco = 1; espaco <= max - i; espaco++){
            printf(".");
        }

        printf("\n");
    }

    return 0;
}