//Biblioteca para input e output
#include <stdio.h>
// Biblioteca para o uso de valor absoluto (somente positivos)
#include <stdlib.h>
//Biblioteca para facilitar operações matemáticas 
#include <math.h>

int main()
{
    int dia1, dia2, mes1, mes2, ano1, ano2;
    int soma_amor;
    int soma_sorte;
    int soma_trabalho;
    int soma_cor;
    
    // Leitura da data de nascimento
    scanf("%d/%d/%d %d/%d/%d", &dia1, &mes1, &ano1, &dia2, &mes2, &ano2);
    
    // soma amor
    soma_amor = (dia1 + mes1 + ano1 + dia2 + mes2 + ano2) * 7;
    soma_amor %= 101;
    printf("Amor: %d%% ", soma_amor);
    
    if (soma_amor < 20) {
        printf("Pessimo dia para se apaixonar.\n");
    } else if (soma_amor < 41) {
        printf("Melhor manter o coracao <3 longe de perigo.\n");
    } else if (soma_amor < 70) {
        printf("Se o papo e as ideias baterem, esta liberado pensar em algo.\n");
    } else if (soma_amor < 81) {
        printf("Saia com o coracao aberto, mas lembre, nem toda troca de olhar em onibus e sinal de romance.\n");
    } else {
        printf("Um dia deslumbrantemente lindo para amar. Ps: Cuidado com a intensidade.\n");
    }
    
    // soma sorte
    soma_sorte = (((dia1 + dia2 + mes1 + mes2) * 9) + abs(ano1 - ano2));
    soma_sorte %= 101;
    printf("Sorte: %d%% ", soma_sorte);
    
    if (soma_sorte < 30) {
        printf("Nem jogue moedas pra cima hoje.");
    } else if (soma_sorte < 51) {
        printf("Melhor nao arriscar.");
    } else if (soma_sorte < 80) {
        printf("Por sua conta em risco.");
    } else if (soma_sorte < 91) {
        printf("Hoje vale a pena arriscar.");
    } else {
        printf("Nao tenha medo de virar cartas hoje.");
    }
    
    printf(" Sem tigrinho nem jogos de azar, por favor!\n");
    
    // soma trabalho
    soma_trabalho = (ano1 + ano2) - ((dia2 + dia1 + mes2 + mes1) * 8);
    soma_trabalho %= 101;
    printf("Trabalho: %d%% ", soma_trabalho);
    
    if (soma_trabalho < 40) {
        printf("Hoje nao sera um dia tao proveitoso, keep calm e faca o basico.\n");
    } else if (soma_trabalho < 51) {
        printf("Segura a emocao, nao xinga ninguem, nao esquece de beber agua.\n");
    } else if (soma_trabalho < 70) {
        printf("Um dia proveitoso com certeza, leve sua simpatia consigo.\n");
    } else if (soma_trabalho < 85) {
        printf("Boas vibracoes hoje, chances podem estar ao seu redor.\n");
    } else {
        printf("Use do maximo de networking possível hoje, dia bom para negocios.\n");
    }

    

    // Soma cor 
    soma_cor = pow(dia1,2) + pow(dia2,2) + pow(mes1,2) + pow(mes2,2) + pow(ano1,2) + pow(ano2,2);
    soma_cor %= 11;
    printf("Cor: ");

    if (soma_cor == 0){
        printf("Cinza.\n");
    }
    if (soma_cor == 1){
        printf("Vermelho.\n");
    }
    if (soma_cor == 2){
        printf("Laranja.\n");
    }
    if (soma_cor == 3){
        printf("Amarelo.\n");
    }
    if (soma_cor == 4){
        printf("Verde.\n");
    }
    if (soma_cor == 5){
        printf("Azul.\n");
    }
    if (soma_cor == 6){
        printf("Roxo.\n");
    }
    if (soma_cor == 7){
        printf("Marrom.\n");
    }
    if (soma_cor == 8){
        printf("Rosa.\n");
    }
    if (soma_cor == 9){
        printf("Preto.\n");
    }
    if (soma_cor == 10){
        printf("Branco.\n");
    }
    return 0;
}