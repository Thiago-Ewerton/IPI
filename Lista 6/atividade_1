#include<stdio.h>
#include<stdlib.h>

int** alocarmatriz(int L, int C){
    //Alocar as linhas
    int ** matriz = (int**)malloc(L * sizeof(int*));

    for(int i = 0; i < L; i++){
        matriz[i] = (int*)malloc(C * sizeof(int));
    }

    return matriz;
}

void lermatriz(int** matriz, int L, int C){
    for(int i = 0; i < L; i++){
        for(int j = 0; j<C; j++){
            scanf("%d", &matriz[i][j]);
        }
    }
}

void aplicarOperacao(int** matriz, int L, int C, int (*operacao)(int)) {
    for (int i = 0; i < L; i++) {
        for (int j = 0; j < C; j++) {
            matriz[i][j] = operacao(matriz[i][j]);
        }
    }
}



//Operações

int dobro(int n) {
    return n * 2;
}

int quadrado(int n) {
    return n * n;
}

int absoluto(int n) {
    return abs(n); 
}

void imprimirMatriz(int** matriz, int L, int C){
    for(int i = 0; i < L; i++){
        for(int j = 0; j < C; j++ ){
            printf("%d",matriz[i][j]);
            if (j < C - 1) {
                printf(" ");
            }
        }
        printf("\n");
        
    }
}

void liberarMatriz(int** matriz, int L){
    for(int i  = 0; i<L; i++){
        free(matriz[i]);
    }
    free(matriz);

}
int main(){

    int L,C,op;

    scanf("%d %d", &L, &C);

    //Alocando 
    int** matriz = alocarmatriz(L, C);

    //lendo matriz
    lermatriz(matriz, L, C);

    //Ler operação
    scanf("%d", &op);

    //Realizar a operação
    if(op == 1){
        aplicarOperacao(matriz, L, C, dobro);

    }else if(op == 2){
        aplicarOperacao(matriz, L, C, quadrado);

    }else if(op == 3){
        aplicarOperacao(matriz, L, C, absoluto);

    }

    //imprimir a matriz
    imprimirMatriz(matriz, L, C);

    //Liberar memoria
    liberarMatriz(matriz, L);

    return 0;
}